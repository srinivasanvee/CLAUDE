# Copy this file to .env and fill in your actual API keys

# Anthropic API Key — required for research_agent.py (original Claude implementation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key — required for research_agent_langgraph.py and research_agent_openai_sdk.py
OPENAI_API_KEY=your_openai_api_key_here

# Brave Search API Key — required for real-time web search in all OpenAI-based agents
# Get your key at: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_search_api_key_here
